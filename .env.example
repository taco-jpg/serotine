# Serotine Environment Variables (Example)

# Required for Cloudflare D1 Local Development
# The binding name MUST match your wrangler.toml
D1_DATABASE_BINDING="serotine_db"

# Optional: Port for local wrangler dev
PORT=8788

# Note: In Cloudflare Pages, your database and other secret bindings 
# are configured in the Cloudflare Dashboard, not via .env files 
# in the production environment.
